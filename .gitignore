# ============================================================================
# SECRETS & SENSITIVE FILES (NEVER COMMIT)
# ============================================================================

# Environment files
.env
.env.*
*.env
*.env.*
!.env.example
!.env.*.example
.envrc
.envrc.*
*.local

# Private keys & certificates
*.pem
*.key
*.p12
*.pfx
*.jks
*.crt
id_rsa*
id_ed25519*
*.gpg
*.asc

# Credentials
credentials.json
secrets.json
service-account*.json
*-keyfile.json
*.secret
*.credentials
application_default_credentials.json

# Cloud configs
.aws/
.gcloud/
.azure/
*.tfstate
*.tfvars

# ============================================================================
# PARANOID MODE - Defense in depth
# ============================================================================

# Anything with "secret" in the name
*secret*
*SECRET*
!hooks/*-secrets.sh

# Anything with "password" in the name
*password*
*PASSWORD*

# Anything with "credential" in the name
*credential*
*CREDENTIAL*

# Anything with "private" in the name
*_private.*
*.private.*

# ============================================================================
# DEPENDENCIES
# ============================================================================

node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnpm-store/

# ============================================================================
# BUILD & TEST OUTPUT
# ============================================================================

dist/
build/
out/
coverage/
htmlcov/
.coverage
*.log

# Next.js
/.next/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# ============================================================================
# OS & EDITOR
# ============================================================================

# macOS
.DS_Store
._*

# Windows
Thumbs.db
Desktop.ini

# IDEs
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# Vim
*.swp
*.swo

# ============================================================================
# TOOL-SPECIFIC
# ============================================================================

# Vercel
.vercel

# Claude
.claude/

# Crucible
.crucible/

# MCP config (local)
.mcp.json

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
